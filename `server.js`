const express=require('express'),QRCode=require('qrcode'),{v4:uuidv4}=require('uuid'),nodemailer=require('nodemailer'),jwt=require('jsonwebtoken'),sqlite3=require('sqlite3').verbose(),bodyParser=require('body-parser'),cors=require('cors'),path=require('path'),app=express(),port=process.env.PORT||3e3;app.use(bodyParser.json());app.use(cors());app.use(express.static('public'));const config={EVENT_NAME:'Intermediate Fiddle Academy - RockyGrass 2026',OFFICE_PHONE:'720-414-5939',FROM_EMAIL:'"Planet Bluegrass Office" <academy@bluegrass.com>',SMTP_USER:process.env.EMAIL_USER||'yourgmail@gmail.com',SMTP_PASS:process.env.EMAIL_PASS||'',JWT_SECRET:process.env.JWT_SECRET||'fiddle2026'};const db=new sqlite3.Database(':memory:');db.run(`CREATE TABLE tickets(id TEXT PRIMARY KEY,orderNumber TEXT,originalBuyer TEXT,currentOwner TEXT,currentEmail TEXT,qrData TEXT,transfers INTEGER DEFAULT 0,used BOOLEAN DEFAULT 0,created TEXT DEFAULT CURRENT_TIMESTAMP)`);const transporter=nodemailer.createTransporter({service:'gmail',auth:{user:config.SMTP_USER,pass:config.SMTP_PASS}});app.post('/api/purchase-pass',async(req,res)=>{const{orderNumber,buyerEmail,buyerName,instrumentLevel}=req.body;const ticketId=uuidv4(),qrData=jwt.sign({id:ticketId,orderNumber,owner:buyerName,email:buyerEmail,instrument:instrumentLevel,type:'fiddle-pass'},config.JWT_SECRET,{expiresIn:'1y'});db.run(`INSERT INTO tickets(id,orderNumber,originalBuyer,currentOwner,currentEmail,qrData)VALUES(?,?,?,?,?,?)`,[ticketId,orderNumber,buyerName,buyerName,buyerEmail,qrData]);const qrImage=await QRCode.toDataURL(qrData);await transporter.sendMail({from:config.FROM_EMAIL,to:buyerEmail,subject:`Fiddle Academy Order #${orderNumber.slice(-6)}`,html:`<div style="font-family:Arial;max-width:600px;margin:20px auto;border:1px solid #ddd;padding:20px"><img src="https://bluegrass.com/wp-content/uploads/2020/06/planet-bluegrass-logo.png"width=250><h2>Intermediate Fiddle Academy Pass</h2><p>Thank you <strong>${buyerName}</strong>!</p><p><strong>Order:</strong>${orderNumber}</p><div style="text-align:center;background:#fff;padding:20px"><img src="${qrImage}"style="width:280px;border:2px solid#4CAF50"><p>Present at RockyGrass check-in</p></div><p><a href="${req.protocol}://${req.get('host')}/transfer.html">Transfer Pass (1-time)</a></p><hr><small>Planet Bluegrass • Lyons CO</small></div>`,attachments:[{filename:`Fiddle-${orderNumber.slice(-6)}.png`,content:qrImage.split(',')[1],cid:'qrcode'}]});res.json({success:true,orderNumber,qrPreview:qrImage})});app.post('/api/transfer-request',async(req,res)=>{const{orderNumber,originalEmail,newStudentName,newStudentEmail}=req.body;db.get(`SELECT transfers FROM tickets WHERE orderNumber=? AND currentEmail=?`,[orderNumber,originalEmail],async(err,ticket)=>{if(!ticket||ticket.transfers>=1)return res.json({error:'Only 1 transfer - Planet Bluegrass policy'});const newId=uuidv4(),newQrData=jwt.sign({id:newId,orderNumber,owner:newStudentName,email:newStudentEmail,type:'fiddle-pass-transferred'},config.JWT_SECRET);db.run(`UPDATE tickets SET currentOwner=?,currentEmail=?,qrData=?,transfers=1 WHERE orderNumber=?`,[newStudentName,newStudentEmail,newQrData,orderNumber]);const newQr=await QRCode.toDataURL(newQrData);await transporter.sendMail({from:config.FROM_EMAIL,to:originalEmail,subject:'Fiddle Academy Transfer Processed',html:`<div><img src="https://bluegrass.com/wp-content/uploads/2020/06/planet-bluegrass-logo.png"><h2>Transfer Complete</h2><p>Order: ${orderNumber}<br>New Student: ${newStudentName}<br>FINAL transfer - original invalid</p><p>${config.OFFICE_PHONE}</p></div>`});await transporter.sendMail({from:config.FROM_EMAIL,to:newStudentEmail,subject:'🎻 Fiddle Academy Pass Transferred to You!',html:`<div style="background:#f9f9f9"><img src="https://bluegrass.com/wp-content/uploads/2020/06/planet-bluegrass-logo.png"><h2>Welcome ${newStudentName}!</h2><div style="text-align:center"><img src="${newQr}"style="width:300px;border:3px solid#4CAF50"><p>Check-in under YOUR name</p></div><p>Original pass invalid. Call ${config.OFFICE_PHONE}</p></div>`,attachments:[{filename:'Fiddle-Pass.png',content:newQr.split(',')[1],cid:'qrcode'}]});res.json({success:true,message:'Planet Bluegrass emails sent'})})});app.post('/api/validate-pass',(req,res)=>{const{qrData}=req.body;try{const decoded=jwt.verify(qrData,config.JWT_SECRET);db.get(`SELECT*FROM tickets WHERE qrData=? AND used=0`,[qrData],(err,ticket)=>{if(!ticket)return res.json({valid:false,error:'Used/invalid'});db.run(`UPDATE tickets SET used=1 WHERE id=?`,[decoded.id]);res.json({valid:true,owner:ticket.currentOwner,order:ticket.orderNumber})})}catch{res.json({valid:false})}});app.listen(port,()=>console.log(`Fiddle Academy LIVE: ${port}`));
