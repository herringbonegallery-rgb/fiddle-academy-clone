<!DOCTYPE html><html><head><title>Transfer Fiddle Pass</title><style>body{font-family:Arial;margin:50px auto;max-width:500px;padding:30px;border:1px solid#ddd;background:#f9f9f9}input,button{width:100%;padding:12px;margin:10px 0;font-size:16px}button{background:#4CAF50;color:white;border:none;cursor:pointer}.logo{width:250px;display:block;margin:0 auto 20px}</style></head><body><img src="https://bluegrass.com/wp-content/uploads/2020/06/planet-bluegrass-logo.png" class="logo"><h1>🔄 Transfer Academy Pass</h1><p>1-time transfer only - Planet Bluegrass policy</p><form id="transfer"><input type="text" id="orderNumber" placeholder="Order Number" required><input type="email" id="originalEmail" placeholder="Your Email (original buyer)" required><input type="text" id="newStudentName" placeholder="New Student Full Name" required><input type="email" id="newStudentEmail" placeholder="New Student Email" required><button type="submit">Request Transfer (Office Processed)</button></form><div id="result"></div><script>document.getElementById('transfer').onsubmit=async e=>{e.preventDefault();const data={orderNumber:document.getElementById('orderNumber').value,originalEmail:document.getElementById('originalEmail').value,newStudentName:document.getElementById('newStudentName').value,newStudentEmail:document.getElementById('newStudentEmail').value};const res=await fetch('/api/transfer-request',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});const result=await res.json();document.getElementById('result').innerHTML=`<h3>${result.success?'✅ TRANSFERRED':'❌ Error'}</h3><p>${result.message||result.error}</p>`;};</script><p style="text-align:center;font-size:12px">Call <a href="tel:720-414-5939">720-414-5939</a> | <a href="/">Buy Pass</a></p></body></html>
